# =============================================================================
# HOST PORT MAPPINGS  (services exposed to the host machine)
# Change these to avoid conflicts with other local services.
#
# NOT listed here (internal-only, never exposed):
#   PostgreSQL primary  — connect via: docker compose exec postgres psql -U creditunder
#   PostgreSQL replica  — connect via: docker compose exec postgres-replica psql -U creditunder
#   Kafka               — publish via: docker compose exec crm python -m mockups.crm.publisher
# =============================================================================
DMS_PORT=8001
EDW_PORT=8002
CRM_PORT=8003
WORKBENCH_API_PORT=8004
WORKBENCH_UI_PORT=8081

# =============================================================================
# KAFKA  (internal to Docker — all containers connect via kafka:9092)
# These are app-level settings, not connection addresses.
# =============================================================================
KAFKA_TOPIC=credit-applications
KAFKA_CONSUMER_GROUP=creditunder-processor

# =============================================================================
# AI SERVICE  (OpenAI-compatible endpoint)
# Option A: set OPENAI_API_KEY to use OpenAI directly (AI_BASE_URL / AI_API_KEY ignored)
# Option B: set AI_BASE_URL + AI_API_KEY for any OpenAI-compatible endpoint
# =============================================================================
OPENAI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4o

# =============================================================================
# MOCKUP SERVICE URLs
# Used only when running the processor or workbench LOCALLY (outside Docker).
# When running inside Docker, docker-compose.yml overrides these with internal
# service names (http://dms:8001, http://edw:8002, http://crm:8003).
# Ports must match DMS_PORT / EDW_PORT / CRM_PORT above.
# =============================================================================
DMS_BASE_URL=http://localhost:8001
EDW_BASE_URL=http://localhost:8002
CRM_BASE_URL=http://localhost:8003
