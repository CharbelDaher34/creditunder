# --- Docker-compose host port mappings ---
# Change these to avoid conflicts with other local services.
# If you change a port here, also update the corresponding URL below.
POSTGRES_PORT=5432
KAFKA_EXTERNAL_PORT=19092
DMS_PORT=8001
EDW_PORT=8002
CRM_PORT=8003
WORKBENCH_API_PORT=8004
WORKBENCH_UI_PORT=8081

# Database (port must match POSTGRES_PORT above)
DATABASE_URL=postgresql+asyncpg://creditunder:creditunder@localhost:5432/creditunder

# Kafka KRaft (port must match KAFKA_EXTERNAL_PORT above)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_TOPIC=credit-applications
KAFKA_CONSUMER_GROUP=creditunder-processor

# AI Service — OpenAI-compatible endpoint
# Option A: set OPENAI_API_KEY to use OpenAI directly (ignores AI_BASE_URL / AI_API_KEY)
OPENAI_API_KEY=
# Option B: custom OpenAI-compatible endpoint
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4o
AI_CONFIDENCE_THRESHOLD=0.7

# Mockup services (ports must match DMS_PORT / EDW_PORT / CRM_PORT above)
DMS_BASE_URL=http://localhost:8001
EDW_BASE_URL=http://localhost:8002
CRM_BASE_URL=http://localhost:8003
