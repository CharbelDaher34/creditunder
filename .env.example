# Database
DATABASE_URL=postgresql+asyncpg://creditunder:creditunder@localhost:5432/creditunder

# Kafka (Redpanda external listener for host-side access)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_TOPIC=credit-applications
KAFKA_CONSUMER_GROUP=creditunder-processor

# AI Service — OpenAI-compatible endpoint
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4o
AI_CONFIDENCE_THRESHOLD=0.7

# Mockup services (running via docker-compose)
DMS_BASE_URL=http://localhost:8001
EDW_BASE_URL=http://localhost:8002
